{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@rgp/domain": ["packages/domain/src/index.ts"],
      "@rgp/ui": ["packages/ui/src/index.ts"],
      "@rgp/api-client": ["packages/api-client/src/index.ts"]
    }
  }
}
